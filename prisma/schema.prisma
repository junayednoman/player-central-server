generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Auth {
  id                         String                     @id @default(uuid())
  email                      String                     @unique
  password                   String
  role                       UserRole
  status                     UserStatus                 @default(PENDING)
  loginProvider              LoginProvider
  fcmToken                   String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  otp                        OTP?
  profile                    Profile?
  notifications              Notification[]
  playerProfile              PlayerProfile?
  coachProfile               CoachProfile?
  scoutProfile               ScoutProfile?
  parentProfile              ParentProfile?
  reactions                  Reaction[]
  comments                   Comment[]
  coachAvailabilityBlocks    CoachAvailabilityBlock[]   @relation("CoachAvailabilityBlocks")
  coachChallenges            Challenge[]                @relation("CoachChallenges")
  coachSessionBookings       SessionBooking[]           @relation("CoachSessionBookings")
  playerSessionBookings      SessionBooking[]           @relation("PlayerSessionBookings")
  coachCustomSessionBookings CustomSessionBooking[]     @relation("CoachCustomSessionBookings")
  scoutInvitations           Invitation[]               @relation("ScoutInvitations")
  playerInvitations          Invitation[]               @relation("PlayerInvitations")
  playerPosts                Post[]                     @relation("PlayerPosts")
  followingRelations         Following[]                @relation("FollowingFollowing")
  followerRelations          Following[]                @relation("FollowingFollower")
  coachBookmarks             PlayerBookmark[]           @relation("CoachBookmarks")
  playerBookmarks            PlayerBookmark[]           @relation("PlayerBookmarks")
  scoutShortlists            PlayerShortlist[]          @relation("ScoutShortlists")
  playerShortlists           PlayerShortlist[]          @relation("PlayerShortlists")
  playerBookingApprovals     BookingApprovalRequest[]   @relation("PlayerBookingApprovals")
  playerPostApprovals        PostApprovalRequest[]      @relation("PlayerPostApprovals")
  playerChallengeApprovals   ChallengeApprovalRequest[] @relation("PlayerChallengeApprovals")
  playerReviewsGiven         Review[]                   @relation("PlayerReviewsGiven")
  coachReviews               Review[]                   @relation("CoachReviews")
  playerChildren             Child[]                    @relation("PlayerChildren")
  challengeSubmissions       ChallengeSubmission[]      @relation("ChallengeSubmissions")
  challengeReactions         ChallengeReaction[]        @relation("ChallengeReactions")
  challengeComments          ChallengeComment[]         @relation("ChallengeComments")

  @@map("auth")
}

model OTP {
  id                String     @id @default(uuid())
  authId            String     @unique
  auth              Auth       @relation(fields: [authId], references: [id])
  otp               String
  purpose           OTPPurpose
  expires           DateTime
  attempts          Int        @default(0)
  isVerified        Boolean    @default(false)
  resetTokenHash    String?
  resetTokenExpires DateTime?
  createdAt         DateTime   @default(now())

  @@unique([authId, purpose])
  @@map("otp")
}

model Profile {
  id        String   @id @default(uuid())
  authId    String   @unique
  auth      Auth     @relation(fields: [authId], references: [id])
  name      String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

model PlayerProfile {
  id                  String         @id @default(uuid())
  authId              String         @unique
  auth                Auth           @relation(fields: [authId], references: [id])
  dob                 DateTime
  height              String
  position            PlayerPosition
  bio                 String
  completedChallenges Int            @default(0)
  uploadStreaks       Int            @default(0)
  shortListedCount    Int            @default(0)
  invitationCount     Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model CoachProfile {
  id           String             @id @default(uuid())
  authId       String             @unique
  auth         Auth               @relation(fields: [authId], references: [id])
  experience   Int
  location     String
  teams        String[]
  certificate  String
  price        Float
  sessionTypes CoachSessionType[]
  mode         CoachSessionMode
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model ScoutProfile {
  id           String     @id @default(uuid())
  authId       String     @unique
  auth         Auth       @relation(fields: [authId], references: [id])
  organization String
  level        ScoutLevel
  badge        String
  intro        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ParentProfile {
  id             String   @id @default(uuid())
  authId         String   @unique
  auth           Auth     @relation(fields: [authId], references: [id])
  defaultChildId String?
  phone          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CoachAvailabilityBlock {
  id          String                       @id @default(uuid())
  coachAuthId String
  coach       Auth                         @relation("CoachAvailabilityBlocks", fields: [coachAuthId], references: [id])
  type        CoachAvailabilityType
  isRecurring Boolean
  dayOfWeek   CoachAvailabilityDaysOfWeek?
  startTime   DateTime?                    @db.Time
  endTime     DateTime?                    @db.Time
  startAt     DateTime?                    @db.Timestamptz
  endAt       DateTime?                    @db.Timestamptz
  validFrom   DateTime?                    @db.Date
  validUntil  DateTime?                    @db.Date
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
}

model Challenge {
  id               String                     @id @default(uuid())
  coachAuthId      String
  coach            Auth                       @relation("CoachChallenges", fields: [coachAuthId], references: [id])
  category         PlayerPosition
  video            String
  title            String
  instruction      String
  difficulty       ChallengeDifficulty
  shareCount       Int                        @default(0)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  approvalRequests ChallengeApprovalRequest[]
  submissions      ChallengeSubmission[]
  reactions        ChallengeReaction[]
  comments         ChallengeComment[]
}

model ChallengeSubmission {
  id          String    @id @default(uuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  playerId    String    @map("playerId")
  player      Auth      @relation("ChallengeSubmissions", fields: [playerId], references: [id])
  video       String
  createdAt   DateTime  @default(now())

  @@map("challenge_submission")
}

model ChallengeReaction {
  id          String    @id @default(uuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  authId      String
  auth        Auth      @relation("ChallengeReactions", fields: [authId], references: [id])
  createdAt   DateTime  @default(now())
}

model ChallengeComment {
  id          String    @id @default(uuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  authorId    String
  author      Auth      @relation("ChallengeComments", fields: [authorId], references: [id])
  text        String
  isEdited    Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model SessionBooking {
  id               String                   @id @default(uuid())
  coachAuthId      String
  coach            Auth                     @relation("CoachSessionBookings", fields: [coachAuthId], references: [id])
  playerAuthId     String
  player           Auth                     @relation("PlayerSessionBookings", fields: [playerAuthId], references: [id])
  sessionType      CoachSessionType
  sessionMode      CoachSessionMode
  startAt          DateTime
  endAt            DateTime
  status           CoachingSessionStatus
  bookedAt         DateTime                 @default(now())
  approvalRequests BookingApprovalRequest[]
}

model CustomSessionBooking {
  id            String                @id @default(uuid())
  coachAuthId   String
  coach         Auth                  @relation("CoachCustomSessionBookings", fields: [coachAuthId], references: [id])
  playerAuthIds String[]
  sessionType   CoachSessionType
  maxPlayers    Int
  mode          CoachSessionMode
  startAt       DateTime
  endAt         DateTime
  status        CoachingSessionStatus
  bookedAt      DateTime              @default(now())
}

model Invitation {
  id             String   @id @default(uuid())
  scoutAuthId    String
  scout          Auth     @relation("ScoutInvitations", fields: [scoutAuthId], references: [id])
  playerAuthId   String
  player         Auth     @relation("PlayerInvitations", fields: [playerAuthId], references: [id])
  trialDate      DateTime
  street         String
  buildingNumber String
  postCode       String
  instruction    String
  sentAt         DateTime @default(now())
}

model Post {
  id               String                @id @default(uuid())
  playerAuthId     String
  player           Auth                  @relation("PlayerPosts", fields: [playerAuthId], references: [id])
  caption          String
  video            String
  position         PlayerPosition
  difficultyType   ChallengeDifficulty
  type             PostType
  status           PostStatus
  shareCount       Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  approvalRequests PostApprovalRequest[]
  reactions        Reaction[]
  comments         Comment[]
}

model Reaction {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id])
  authId String
  auth   Auth   @relation(fields: [authId], references: [id])
}

model Comment {
  id        String   @id @default(uuid())
  authorId  String
  author    Auth     @relation(fields: [authorId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  text      String
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Following {
  id              String @id @default(uuid())
  followingAuthId String
  following       Auth   @relation("FollowingFollowing", fields: [followingAuthId], references: [id])
  followerAuthId  String
  follower        Auth   @relation("FollowingFollower", fields: [followerAuthId], references: [id])
}

model PlayerBookmark {
  id           String @id @default(uuid())
  coachAuthId  String
  coach        Auth   @relation("CoachBookmarks", fields: [coachAuthId], references: [id])
  playerAuthId String
  player       Auth   @relation("PlayerBookmarks", fields: [playerAuthId], references: [id])
}

model PlayerShortlist {
  id           String @id @default(uuid())
  scoutAuthId  String
  scout        Auth   @relation("ScoutShortlists", fields: [scoutAuthId], references: [id])
  playerAuthId String
  player       Auth   @relation("PlayerShortlists", fields: [playerAuthId], references: [id])
}

model BookingApprovalRequest {
  id           String                @id @default(uuid())
  playerAuthId String
  player       Auth                  @relation("PlayerBookingApprovals", fields: [playerAuthId], references: [id])
  bookingId    String
  booking      SessionBooking        @relation(fields: [bookingId], references: [id])
  status       ApprovalRequestStatus
  requestedAt  DateTime              @default(now())
}

model PostApprovalRequest {
  id           String                @id @default(uuid())
  playerAuthId String
  player       Auth                  @relation("PlayerPostApprovals", fields: [playerAuthId], references: [id])
  postId       String
  post         Post                  @relation(fields: [postId], references: [id])
  status       ApprovalRequestStatus
  requestedAt  DateTime              @default(now())
}

model ChallengeApprovalRequest {
  id           String                @id @default(uuid())
  playerAuthId String
  player       Auth                  @relation("PlayerChallengeApprovals", fields: [playerAuthId], references: [id])
  challengeId  String
  challenge    Challenge             @relation(fields: [challengeId], references: [id])
  video        String?
  status       ApprovalRequestStatus
  requestedAt  DateTime              @default(now())
}

model Review {
  id          String   @id @default(uuid())
  giverAuthId String
  giver       Auth     @relation("PlayerReviewsGiven", fields: [giverAuthId], references: [id])
  coachAuthId String
  coach       Auth     @relation("CoachReviews", fields: [coachAuthId], references: [id])
  text        String
  rating      Float
  givenAt     DateTime @default(now())
}

model Child {
  id            String            @id @default(uuid())
  playerAuthId  String
  player        Auth              @relation("PlayerChildren", fields: [playerAuthId], references: [id])
  parentAuthIds String[]
  relationship  ChildRelationShip
  status        ChildStatus
}

model Notification {
  id         String   @id @default(uuid())
  receiver   Auth     @relation(fields: [receiverId], references: [id])
  receiverId String
  title      String
  body       String
  date       DateTime @default(now())

  @@map("notification")
}

model Legal {
  id             String   @id @default(uuid())
  privacyPolicy  String
  termsCondition String
  aboutUs        String
  updatedAt      DateTime @updatedAt

  @@map("legal")
}

enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
  DELETED
}

enum LoginProvider {
  FACEBOOK
  GOOGLE
  EMAIL
}

enum UserRole {
  ADMIN
  PLAYER
  SCOUT
  COACH
  PARENT
}

enum PlayerPosition {
  MIDFIELDER
  ATTACKER
  DEFENDER
  GOALKEEPER
}

enum CoachSessionType {
  ONE_TO_ONE
  GROUP
  SKILL_BASED
}

enum CoachSessionMode {
  PLAYER_TRAVELS
  COACH_TRAVELS
}

enum ScoutLevel {
  LOCAL
  REGIONAL
  NATIONAL
}

enum CoachAvailabilityType {
  AVAILABLE
  BLACKOUT
}

enum CoachAvailabilityDaysOfWeek {
  D0
  D1
  D2
  D3
  D4
  D5
  D6
}

enum ChildRelationShip {
  FATHER
  MOTHER
  UNCLE
  OTHER
}

enum ChildStatus {
  PENDING
  APPROVED
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum PostType {
  COMMUNITY
  PREMIUM
}

enum PostStatus {
  PENDING
  APPROVED
}

enum CoachingSessionStatus {
  PENDING
  APPROVED
  UPCOMING
  COMPLETED
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OTPPurpose {
  VERIFY_ACCOUNT
  RESET_PASSWORD
}
